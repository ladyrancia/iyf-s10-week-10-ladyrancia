{
  "info": {
    "name": "Node.js Express API - CRUD Operations",
    "description": "Complete REST API with Posts, Users, and Comments. Demonstrates Express.js, middleware, error handling, route parameters, query strings, and file-based storage using fs and path modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        },
        "description": "Check server health and get timestamp"
      },
      "response": []
    },
    {
      "name": "Analytics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/stats",
          "host": ["{{baseUrl}}"],
          "path": ["api", "stats"]
        },
        "description": "Get overall statistics (posts, users, comments, total likes)"
      },
      "response": []
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "GET All Posts (with filtering, sorting, pagination)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts?author=John&search=Express&sort=newest&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"],
              "query": [
                { "key": "author", "value": "John", "description": "Filter by author name (optional)" },
                { "key": "search", "value": "Express", "description": "Search in title and content (optional)" },
                { "key": "sort", "value": "newest", "description": "Sort by: newest, oldest, popular (default: newest)" },
                { "key": "page", "value": "1", "description": "Page number for pagination (default: 1)" },
                { "key": "limit", "value": "10", "description": "Items per page (default: 10)" }
              ]
            },
            "description": "Retrieve all posts with optional filtering, sorting, and pagination. Demonstrates query string usage."
          },
          "response": []
        },
        {
          "name": "GET Single Post by ID (Route Parameter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "1"],
              "description": "Use numeric post ID as route parameter"
            },
            "description": "Retrieve a single post by its ID. Demonstrates route parameters (:id)."
          },
          "response": []
        },
        {
          "name": "POST Create New Post",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My New Post\",\n  \"content\": \"This is the content of my new post. It must be at least 10 characters long.\",\n  \"author\": \"Jane Doe\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"]
            },
            "description": "Create a new blog post. Validates title (min 3 chars), content (min 10 chars), author (min 2 chars). Returns 201 Created with the new post object."
          },
          "response": []
        },
        {
          "name": "PUT Update Post",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"content\": \"Updated content with more than 10 characters\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "1"]
            },
            "description": "Update an existing post. Uses route parameter to identify the post. Returns updated post with timestamp."
          },
          "response": []
        },
        {
          "name": "DELETE Post",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts/3",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "3"]
            },
            "description": "Delete a post by ID. Also deletes all associated comments. Returns 204 No Content on success."
          },
          "response": []
        },
        {
          "name": "PATCH Like Post",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/posts/1/like",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts", "1", "like"]
            },
            "description": "Increment the like count for a post. Demonstrates custom action route."
          },
          "response": []
        }
      ]
    },
