        {
          "name": "PUT Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"email\": \"updated@example.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/users/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1"]
            },
            "description": "Update an existing user"
          },
          "response": []
        },
        {
          "name": "DELETE User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/users/2",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "2"]
            },
            "description": "Delete a user by ID. Returns 204 No Content."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Comments",
      "item": [
        {
          "name": "GET All Comments (with optional postId filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/comments?postId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments"],
              "query": [
                { "key": "postId", "value": "1", "description": "Filter comments by post ID (optional)" }
              ]
            },
            "description": "Retrieve all comments. Use postId query parameter to filter comments for a specific post."
          },
          "response": []
        },
        {
          "name": "GET Comment by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/comments/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "1"]
            },
            "description": "Retrieve a single comment by ID"
          },
          "response": []
        },
        {
          "name": "POST Create Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"postId\": 1,\n  \"author\": \"Commenter\",\n  \"content\": \"This is a great post!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments"]
            },
            "description": "Create a new comment linked to a post (postId required)"
          },
          "response": []
        },
        {
          "name": "PUT Update Comment",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"author\": \"Updated Author\",\n  \"content\": \"Updated comment content\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/comments/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "1"]
            },
            "description": "Update comment author and content"
          },
          "response": []
        },
        {
          "name": "DELETE Comment",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/comments/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "comments", "1"]
            },
            "description": "Delete a comment by ID"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Handling Examples",
      "item": [
        {
          "name": "404 Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/nonexistent",
              "host": ["{{baseUrl}}"],
              "path": ["api", "nonexistent"]
            },
            "description": "Returns 404 with error JSON: {\"error\":{\"message\":\"Not Found\",\"status\":404}}"
          },
          "response": []
        },
        {
          "name": "400 Bad Request - Validation Error",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"ab\",\n  \"content\": \"short\",\n  \"author\": \"A\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/posts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "posts"]
            },
            "description": "Validation middleware returns 400 with array of validation errors"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
