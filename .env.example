# Server Configuration
PORT=3000
NODE_ENV=development

# Data Storage
DATA_DIR=./data

# Security (optional)
# JWT_SECRET=your-secret-key-here

# Rate Limiting (optional)
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100

# CORS (optional)
# CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info
