{
  "name": "advanced-nodejs-portfolio",
  "version": "1.0.0",
  "description": "Learning showcase: Clean Architecture, advanced patterns, real-time features, testing",
  "main": "dist/src/presentation/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/presentation/server.ts",
    "build": "tsc",
    "start": "node dist/src/presentation/server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "swagger": "ts-node src/presentation/swagger/generate.ts"
  },
  "keywords": [
    "node.js",
    "typescript",
    "clean-architecture",
    "learning",
    "portfolio"
  ],
  "author": "Developer",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "csv-writer": "^1.6.0",
    "diff": "^5.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "marked": "^9.1.2",
    "node-cron": "^3.0.2",
    "pdfkit": "^0.13.0",
    "sanitize-html": "^2.11.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/diff": "^5.0.3",
    "@types/express": "^4.17.17",
    "@types/fs-extra": "^11.0.4",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.7.0",
    "@types/node-cron": "^3.0.8",
    "@types/pdfkit": "^0.12.11",
    "@types/sanitize-html": "^2.6.1",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "@types/uuid": "^9.0.2",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "husky": "^8.0.3",
    "jest": "^29.6.1",
    "prettier": "^3.0.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
